{
  "_description": "Gateway registers its skills and tools, service acknowledges",
  "gateway_sends": {
    "type": "register",
    "skills": [
      {
        "type": "mcp_server",
        "id": "postgresql",
        "name": "PostgreSQL",
        "description": "Query and inspect PostgreSQL databases",
        "tools": [
          {
            "name": "query",
            "description": "Execute a read-only SQL query",
            "inputSchema": {
              "type": "object",
              "properties": {
                "sql": { "type": "string", "description": "SQL query to execute" }
              },
              "required": ["sql"]
            }
          },
          {
            "name": "list_tables",
            "description": "List all tables in the database",
            "inputSchema": {
              "type": "object",
              "properties": {},
              "required": []
            }
          }
        ]
      }
    ]
  },
  "service_responds": {
    "type": "registered",
    "skillCount": 1,
    "toolCount": 2
  }
}
