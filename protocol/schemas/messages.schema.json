{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://journal.one/schemas/gateway/messages.schema.json",
  "title": "Journal Gateway Protocol Messages",
  "description": "All WebSocket message types exchanged between gateway and service",

  "$defs": {
    "AuthenticateMessage": {
      "type": "object",
      "description": "Sent by the gateway immediately after WebSocket connection opens",
      "properties": {
        "type": { "const": "authenticate" },
        "token": {
          "type": "string",
          "description": "Gateway auth token (gw_* prefix)"
        },
        "protocolVersion": {
          "type": "number",
          "description": "Protocol version number"
        },
        "gatewayVersion": {
          "type": "string",
          "description": "Gateway software version (semver)"
        }
      },
      "required": ["type", "token", "protocolVersion", "gatewayVersion"],
      "additionalProperties": false
    },

    "RegisterMessage": {
      "type": "object",
      "description": "Sent by the gateway after successful authentication to declare available integrations",
      "properties": {
        "type": { "const": "register" },
        "integrations": {
          "type": "array",
          "items": { "$ref": "integrations.schema.json#/$defs/Integration" },
          "description": "Array of integration registrations"
        }
      },
      "required": ["type", "integrations"],
      "additionalProperties": false
    },

    "ToolResultMessage": {
      "type": "object",
      "description": "Sent by the gateway in response to a tool_call with successful result",
      "properties": {
        "type": { "const": "tool_result" },
        "requestId": {
          "type": "string",
          "description": "Correlates with the original tool_call requestId"
        },
        "result": { "$ref": "integrations.schema.json#/$defs/ToolResult" }
      },
      "required": ["type", "requestId", "result"],
      "additionalProperties": false
    },

    "ToolErrorMessage": {
      "type": "object",
      "description": "Sent by the gateway in response to a tool_call when execution fails",
      "properties": {
        "type": { "const": "tool_error" },
        "requestId": {
          "type": "string",
          "description": "Correlates with the original tool_call requestId"
        },
        "error": { "$ref": "errors.schema.json#/$defs/GatewayError" }
      },
      "required": ["type", "requestId", "error"],
      "additionalProperties": false
    },

    "PongMessage": {
      "type": "object",
      "description": "Sent by the gateway in response to a ping",
      "properties": {
        "type": { "const": "pong" }
      },
      "required": ["type"],
      "additionalProperties": false
    },

    "AuthenticatedMessage": {
      "type": "object",
      "description": "Sent by the service after successful authentication",
      "properties": {
        "type": { "const": "authenticated" },
        "organizationId": {
          "type": "string",
          "description": "Organization ID"
        },
        "organizationName": {
          "type": "string",
          "description": "Organization display name"
        }
      },
      "required": ["type", "organizationId"],
      "additionalProperties": false
    },

    "AuthErrorMessage": {
      "type": "object",
      "description": "Sent by the service when authentication fails",
      "properties": {
        "type": { "const": "auth_error" },
        "error": {
          "type": "string",
          "description": "Error description"
        }
      },
      "required": ["type", "error"],
      "additionalProperties": false
    },

    "RegisteredMessage": {
      "type": "object",
      "description": "Sent by the service after successful integration registration",
      "properties": {
        "type": { "const": "registered" },
        "integrationCount": {
          "type": "number",
          "description": "Number of registered integrations"
        },
        "toolCount": {
          "type": "number",
          "description": "Total number of registered tools"
        }
      },
      "required": ["type", "integrationCount", "toolCount"],
      "additionalProperties": false
    },

    "ToolCallMessage": {
      "type": "object",
      "description": "Sent by the service to invoke a tool on a registered integration",
      "properties": {
        "type": { "const": "tool_call" },
        "requestId": {
          "type": "string",
          "description": "Unique request ID for correlation"
        },
        "integrationId": {
          "type": "string",
          "description": "Target integration identifier"
        },
        "toolName": {
          "type": "string",
          "description": "Tool name within the integration"
        },
        "arguments": {
          "type": "object",
          "description": "Tool input arguments"
        }
      },
      "required": ["type", "requestId", "integrationId", "toolName", "arguments"],
      "additionalProperties": false
    },

    "PingMessage": {
      "type": "object",
      "description": "Heartbeat sent by the service",
      "properties": {
        "type": { "const": "ping" }
      },
      "required": ["type"],
      "additionalProperties": false
    },

    "GatewayMessage": {
      "description": "Any message sent from gateway to service",
      "discriminator": { "propertyName": "type" },
      "oneOf": [
        { "$ref": "#/$defs/AuthenticateMessage" },
        { "$ref": "#/$defs/RegisterMessage" },
        { "$ref": "#/$defs/ToolResultMessage" },
        { "$ref": "#/$defs/ToolErrorMessage" },
        { "$ref": "#/$defs/PongMessage" }
      ]
    },

    "ServiceMessage": {
      "description": "Any message sent from service to gateway",
      "discriminator": { "propertyName": "type" },
      "oneOf": [
        { "$ref": "#/$defs/AuthenticatedMessage" },
        { "$ref": "#/$defs/AuthErrorMessage" },
        { "$ref": "#/$defs/RegisteredMessage" },
        { "$ref": "#/$defs/ToolCallMessage" },
        { "$ref": "#/$defs/PingMessage" }
      ]
    }
  }
}
