{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://journal.one/schemas/gateway/integrations.schema.json",
  "title": "Journal Gateway Integration Definitions",
  "description": "Integration, tool, and result type definitions for the gateway protocol",

  "$defs": {
    "ToolDefinition": {
      "type": "object",
      "description": "A tool exposed by an integration",
      "properties": {
        "name": {
          "type": "string",
          "description": "Tool name (unique within an integration)"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of what the tool does"
        },
        "inputSchema": {
          "type": "object",
          "description": "JSON Schema describing the tool's input parameters"
        }
      },
      "required": ["name", "description", "inputSchema"],
      "additionalProperties": false
    },

    "McpServerIntegration": {
      "type": "object",
      "description": "An integration backed by an MCP server process",
      "properties": {
        "type": { "const": "mcp_server" },
        "id": {
          "type": "string",
          "description": "Unique integration identifier"
        },
        "name": {
          "type": "string",
          "description": "Human-readable integration name"
        },
        "description": {
          "type": "string",
          "description": "What this integration provides"
        },
        "tools": {
          "type": "array",
          "items": { "$ref": "#/$defs/ToolDefinition" },
          "description": "Tools exposed by this integration"
        }
      },
      "required": ["type", "id", "name", "description", "tools"],
      "additionalProperties": false
    },

    "AgentIntegration": {
      "type": "object",
      "description": "An integration backed by an agent",
      "properties": {
        "type": { "const": "agent" },
        "id": {
          "type": "string",
          "description": "Unique integration identifier"
        },
        "name": {
          "type": "string",
          "description": "Human-readable integration name"
        },
        "description": {
          "type": "string",
          "description": "What this integration provides"
        },
        "tools": {
          "type": "array",
          "items": { "$ref": "#/$defs/ToolDefinition" },
          "description": "Tools exposed by this integration"
        }
      },
      "required": ["type", "id", "name", "description", "tools"],
      "additionalProperties": false
    },

    "Integration": {
      "description": "An integration registration, discriminated on the type field",
      "oneOf": [
        { "$ref": "#/$defs/McpServerIntegration" },
        { "$ref": "#/$defs/AgentIntegration" }
      ]
    },

    "TextContent": {
      "type": "object",
      "properties": {
        "type": { "const": "text" },
        "text": {
          "type": "string",
          "description": "Text content"
        }
      },
      "required": ["type", "text"],
      "additionalProperties": false
    },

    "ImageContent": {
      "type": "object",
      "properties": {
        "type": { "const": "image" },
        "data": {
          "type": "string",
          "description": "Base64-encoded image data"
        },
        "mimeType": {
          "type": "string",
          "description": "Image MIME type (e.g., image/png)"
        }
      },
      "required": ["type", "data", "mimeType"],
      "additionalProperties": false
    },

    "Content": {
      "description": "A content block in a tool result",
      "oneOf": [
        { "$ref": "#/$defs/TextContent" },
        { "$ref": "#/$defs/ImageContent" }
      ]
    },

    "ToolResult": {
      "type": "object",
      "description": "Result of a tool execution",
      "properties": {
        "content": {
          "type": "array",
          "items": { "$ref": "#/$defs/Content" },
          "description": "Result content blocks"
        },
        "isError": {
          "type": "boolean",
          "description": "Whether the result represents an error"
        }
      },
      "required": ["content"],
      "additionalProperties": false
    }
  }
}
