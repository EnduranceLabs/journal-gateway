{
  "name": "journal-gateway",
  "version": "0.8.0",
  "description": "Outbound gateway for connecting MCP servers and skills to Journal",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "journal",
    "journal-gateway",
    "mcp",
    "model-context-protocol",
    "gateway"
  ],
  "homepage": "https://github.com/EnduranceLabs/journal-gateway#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EnduranceLabs/journal-gateway.git",
    "directory": "gateway"
  },
  "bugs": {
    "url": "https://github.com/EnduranceLabs/journal-gateway/issues"
  },
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js"
    }
  },
  "bin": {
    "journal-gateway": "./dist/main.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "journal-gateway-protocol": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-trace-node": "^2.9.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "dotenv": "^17.3.1",
    "ws": "^8.21.1",
    "zod": "^3.24"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/ws": "^8",
    "typescript": "^5.7",
    "vitest": "^4.1.10"
  }
}
