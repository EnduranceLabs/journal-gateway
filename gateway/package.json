{
  "name": "@journal.one/gateway",
  "version": "0.8.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js"
    }
  },
  "bin": {
    "journal-gateway": "./dist/main.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@journal.one/gateway-protocol": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.56.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.56.0",
    "@opentelemetry/resources": "^1.23.0",
    "@opentelemetry/sdk-metrics": "^1.23.0",
    "@opentelemetry/sdk-trace-node": "^1.23.0",
    "@opentelemetry/semantic-conventions": "^1.23.0",
    "dotenv": "^17.3.1",
    "ws": "^8",
    "zod": "^3.24"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/ws": "^8",
    "typescript": "^5.7",
    "vitest": "^3"
  }
}
