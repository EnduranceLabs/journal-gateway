{
  "$schema": "https://raw.githubusercontent.com/EnduranceLabs/journal-gateway/main/spec/gateway-config.schema.json",
  "mcpServers": [
    {
      "id": "mysql",
      "name": "MySQL",
      "description": "MySQL access through Google MCP Toolbox for Databases.",
      "command": "npx",
      "args": ["-y", "@toolbox-sdk/server", "--prebuilt", "mysql", "--stdio"],
      "envVars": {
        "MYSQL_HOST": "MYSQL_HOST",
        "MYSQL_PORT": "MYSQL_PORT",
        "MYSQL_DATABASE": "MYSQL_DATABASE",
        "MYSQL_USER": "MYSQL_USER",
        "MYSQL_PASSWORD": "MYSQL_PASSWORD"
      }
    }
  ]
}
