# Drives the SHIPPED examples/gateway.json against the Dockerized Postgres.
# The remote-api entry in gateway.json points at a non-existent host and is
# expected to fail and be skipped (resilient startup) — REMOTE_MCP_AUTHORIZATION
# is a dummy so config resolution passes.
JOURNAL_GATEWAY_TOKEN=gw_demo
JOURNAL_GATEWAY_URL=ws://127.0.0.1:8080

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_DATABASE=analytics
POSTGRES_USER=journal_gateway_ro
POSTGRES_PASSWORD=ro_pw

REMOTE_MCP_AUTHORIZATION=Bearer dummy-not-used
