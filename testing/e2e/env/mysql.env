# Loaded by the gateway with --env-file. Points at the Dockerized MySQL
# (docker-compose maps host 3307 -> container 3306) using the dedicated
# read-only user created by sql/mysql-setup.sql.
JOURNAL_GATEWAY_TOKEN=gw_e2e
JOURNAL_GATEWAY_URL=ws://127.0.0.1:8080

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_DATABASE=analytics
MYSQL_USER=journal_gateway_ro
MYSQL_PASSWORD=ro_pw
