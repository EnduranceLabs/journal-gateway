# Loaded by the gateway with --env-file. Points at the Dockerized Postgres
# (docker-compose maps host 5433 -> container 5432) using the dedicated
# read-only role created by sql/postgres-setup.sql.
JOURNAL_GATEWAY_TOKEN=gw_e2e
JOURNAL_GATEWAY_URL=ws://127.0.0.1:8080

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_DATABASE=analytics
POSTGRES_USER=journal_gateway_ro
POSTGRES_PASSWORD=ro_pw
