{
  "name": "journal-gateway-client",
  "version": "0.8.1",
  "description": "TypeScript service-side client for accepting Journal Gateway connections",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "journal",
    "journal-gateway",
    "mcp",
    "model-context-protocol",
    "websocket"
  ],
  "homepage": "https://github.com/EnduranceLabs/journal-gateway#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EnduranceLabs/journal-gateway.git",
    "directory": "clients/typescript"
  },
  "bugs": {
    "url": "https://github.com/EnduranceLabs/journal-gateway/issues"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "journal-gateway-protocol": "workspace:*",
    "ws": "^8.21.1",
    "zod": "^3.24"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/ws": "^8",
    "typescript": "^5.7",
    "vitest": "^4.1.10"
  }
}
